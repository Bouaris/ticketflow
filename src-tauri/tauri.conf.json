{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Ticketflow",
  "version": "1.2.0",
  "identifier": "com.ticketflow.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Ticketflow",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "devtools": true,
        "transparent": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDBBRDBDMUVDQzg0MkVDMjcKUldRbjdFTEk3TUhRQ21TQ1Z4SjJtRDJhM01SWkNqN3BLNlNOK0k1Ulc5VExDU2g1ampRTE5ObjQK",
      "endpoints": [
        "https://github.com/Bouaris/ticketflow/releases/latest/download/latest.json"
      ]
    }
  }
}
